OPENAI_API_KEY=sk-your-key-here

# Demo accounts (seeded on first run in the DB):
#   admin / admin123  (site admin — People import, full access)
#   viewer / viewer123 (standard user — can be shared on events as editor/viewer)
# If the app is reachable beyond this PC (LAN, tunnel, deploy), change these passwords in-app.
# Optional: model override (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Optional: stable sessions in dev (set before LAN or tunnel access)
# FLASK_SECRET_KEY=change-me
#
# ── Dev server bind (default: 127.0.0.1 only) ──
# LAN access from other devices on the same network:
#   FLASK_RUN_HOST=0.0.0.0
#   Then open http://<this-PC-IPv4>:5000 (run ipconfig for IPv4 Address).
#   Windows Firewall (requires Administrator): in elevated CMD or PowerShell run:
#   netsh advfirewall firewall add rule name="SOMTool Flask TCP 5000" dir=in action=allow protocol=TCP localport=5000 profile=private
# Optional port: FLASK_RUN_PORT=5000
# When FLASK_RUN_HOST is 0.0.0.0, FLASK_DEBUG defaults to off unless you set FLASK_DEBUG=true.

# ── Database (Phase 0) ──
# Leave unset to use a local SQLite database at data/somtool.db (dev).
# For production, set a Postgres URL. Render/Heroku "postgres://" URLs are auto-rewritten.
# DATABASE_URL=postgresql://user:pass@host:5432/somtool

# ── Gmail SMTP (fallback only — Resend is now the primary transactional sender) ──
# Generate App Password: Google Account > Security > 2-Step Verification > App Passwords
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Vapi AI Voice Calls ──
VAPI_API_KEY=your-vapi-private-api-key
VAPI_INVITE_ASSISTANT_ID=your-invite-assistant-id
VAPI_INVITE_PHONE_ID=your-invite-phone-number-id
VAPI_FOLLOWUP_ASSISTANT_ID=your-followup-assistant-id
VAPI_FOLLOWUP_PHONE_ID=your-followup-phone-number-id

# ── Real-time web monitoring ──
# How often the full automation pipeline runs (in minutes). Set to 0 to disable.
SCRAPE_INTERVAL_MINUTES=10
# Auto-send update emails when page changes are detected (requires Gmail config above)
AUTO_NOTIFY_ON_CHANGE=true

# ── Full automation engine ──
AUTO_IMPORT_EVENTS=true
AUTO_POPULATE_CONTACTS=true
AUTO_CONTACTS_MAX=20
AUTO_SEND_EMAILS=true
AUTO_FOLLOWUP_DAYS=3
AUTO_EMAIL_BATCH_SIZE=10
AUTO_SCHEDULE_CALLS=false
CALL_DELAY_AFTER_EMAIL_DAYS=2

# ── Phase 1: Observability ──
# Sentry: create a project at https://sentry.io and paste the DSN here
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# PostHog: cloud or self-hosted (host defaults to https://us.i.posthog.com)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Phase 2: Resend + Twilio ──
# Switch between resend|gmail; resend is the default going forward.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM=SOMTool <noreply@yourdomain.com>
RESEND_REPLY_TO=
RESEND_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15555555555

# ── Phase 3: Object storage (S3/R2/Backblaze compatible) ──
# Leave blank for local filesystem fallback (data/uploads/).
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=

# ── Phase 4-5: Integrations Hub (Google) ──
# Create an OAuth Client at https://console.cloud.google.com/apis/credentials
# Add redirect URI: {BASE_URL}/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/integrations/google/callback
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATIONS_ENCRYPTION_KEY=
# Optional: enable "Sign in with Google" button on /login
GOOGLE_SIGNIN_ENABLED=false

# ── Phase 6: Stripe ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET_EVENTS=
STRIPE_WEBHOOK_SECRET_SUBS=
# Create Products/Prices in the Stripe dashboard, paste price IDs here
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_CAMPUS=price_xxx
# Base URL used in Stripe Checkout + Billing Portal return_url
APP_BASE_URL=http://localhost:5000

# ── Phase 7: Apollo.io enrichment ──
APOLLO_API_KEY=

# ── Integrations Hub (Phases C–I) ──────────────────────────
# Every variable below is OPTIONAL. Only set the ones whose provider you want
# to turn on. An admin can always see which keys are missing at /admin/setup.

# Campus
# Canvas LMS (access token is pasted per-user when they connect):
CANVAS_BASE_URL=
# 25Live / EMS (institution SSO; service-account creds):
25LIVE_BASE_URL=
25LIVE_USERNAME=
25LIVE_PASSWORD=
25LIVE_API_TOKEN=
# Handshake career events (partner-gated OAuth):
HANDSHAKE_CLIENT_ID=
HANDSHAKE_CLIENT_SECRET=
HANDSHAKE_REDIRECT_URI=
HANDSHAKE_BASE_URL=https://app.joinhandshake.com
HANDSHAKE_INSTITUTION_ID=
# SIS (Banner | PowerCampus | Workday):
CAMPUS_SIS=
CAMPUS_SIS_BASE_URL=
CAMPUS_SIS_USERNAME=
CAMPUS_SIS_PASSWORD=
CAMPUS_SIS_TENANT=
CAMPUS_SIS_CLIENT_ID=
CAMPUS_SIS_CLIENT_SECRET=
# Qualtrics surveys:
QUALTRICS_API_TOKEN=
QUALTRICS_DATA_CENTER=
# Student-org platform (engage | presence | campusgroups):
CAMPUS_ORG_PLATFORM=
CAMPUS_ORG_BASE_URL=
CAMPUS_ORG_API_KEY=

# Registration & ticketing
EVENTBRITE_CLIENT_ID=
EVENTBRITE_CLIENT_SECRET=
EVENTBRITE_REDIRECT_URI=
EVENTBRITE_WEBHOOK_TOKEN=
LUMA_API_KEY=
# Wallet passes (Apple requires a signed pkpass cert):
APPLE_WALLET_PASS_TYPE_IDENTIFIER=
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_SIGNER_PEM_PATH=
APPLE_WALLET_WWDR_PEM_PATH=
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_JSON=

# CRM & Marketing
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=
HUBSPOT_WEBHOOK_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=
SALESFORCE_LOGIN_URL=https://login.salesforce.com
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_WEBHOOK_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# Ops & Productivity
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
LINEAR_API_KEY=
LINEAR_TEAM_ID=
ASANA_PAT=
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_REALM_ID=
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=
XERO_TENANT_ID=

# Social & Promo
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=
BUFFER_REDIRECT_URI=
HOOTSUITE_CLIENT_ID=
HOOTSUITE_CLIENT_SECRET=
HOOTSUITE_REDIRECT_URI=
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
META_WEBHOOK_SECRET=
LINKEDIN_PAGES_CLIENT_ID=
LINKEDIN_PAGES_CLIENT_SECRET=
LINKEDIN_PAGES_REDIRECT_URI=

# Messaging
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
DISCORD_BOT_TOKEN=
# WhatsApp Business via Twilio reuses Phase 2 TWILIO_* above; only the
# WhatsApp-ready sender number is separate:
TWILIO_WHATSAPP_FROM=

# Identity
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_REDIRECT_URI=
OKTA_DOMAIN=
OKTA_SCIM_TOKEN=

# ── Production (Docker / Render / Railway / Fly) ──
# The Dockerfile runs Gunicorn on 0.0.0.0 using the host-provided PORT (default 5000).
# Required for a public site: set a long random FLASK_SECRET_KEY in the host dashboard.
# Copy the variables above (OPENAI_API_KEY, Gmail, Vapi, etc.) into the host as secrets.
# After first deploy, change default admin/viewer passwords in the app.
#
# Persistent data lives in Postgres when DATABASE_URL is set; otherwise in ./data (SQLite + JSON fallback).
#   Render: add a Postgres instance and set DATABASE_URL. render.yaml already wires this up.
#   Railway: add a Postgres plugin, set DATABASE_URL automatically.
#   Fly.io: fly postgres create and attach.
#
# Always-on: free tiers often sleep after idle; pick a paid / always-on instance if the link must stay instant.
